---
// src/components/ui/NewsletterForm.astro
---

<div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" id="newsletter-form">
  <input
    type="email"
    placeholder="Your email address"
    required
    class="nl-input flex-1 px-5 py-3.5 rounded-full text-bark text-sm border-2 border-transparent focus:border-sage bg-white shadow-md"
    aria-label="Email address"
    id="email-input"
  />
  <button 
    type="submit"
    class="bg-sage hover:bg-white text-forest font-semibold px-7 py-3.5 rounded-full transition-colors shadow-md whitespace-nowrap"
    id="submit-btn"
  >
    Subscribe Free
  </button>
</div>
<p class="text-sage/60 text-xs mt-4">Unsubscribe anytime. We respect your privacy.</p>

<script>
  const form = document.getElementById('newsletter-form');
  const btn = document.getElementById('submit-btn');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('email-input') as HTMLInputElement;
    
    if (input?.value) {
      btn.textContent = 'Subscribing...';
      btn.disabled = true;
      
      // Simulate API call
      await new Promise(resolve => setTimeout(resolve, 1000));
      
      btn.textContent = 'Subscribed! 🎉';
      btn.classList.add('bg-white');
      input.value = '';
      
      setTimeout(() => {
        btn.textContent = 'Subscribe Free';
        btn.disabled = false;
        btn.classList.remove('bg-white');
      }, 3000);
    }
  });
</script>