---
// src/components/ui/CategoryCard.astro
interface Props {
  title: string;
  slug: string;
  count: number;
  image: string;
  emoji: string;
}

const { title, slug, count, image, emoji } = Astro.props;
---

<a href={`/${slug}/`} class="cat-card group bg-white rounded-2xl overflow-hidden shadow-soft border border-sage/10 flex flex-col h-full dark:bg-gray-800 dark:border-gray-700/20">
  <div class="relative h-44 overflow-hidden bg-gradient-warm">
    <img src={image} alt={title} class="w-full h-full object-cover post-img" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
    <span class="absolute top-4 left-4 text-3xl drop-shadow-lg">{emoji}</span>
  </div>
  <div class="p-6 flex-1 flex flex-col justify-between">
    <h3 class="font-display text-lg text-bark group-hover:text-forest transition-colors dark:text-gray-100 dark:group-hover:text-leaf">{title}</h3>
    <p class="text-gray-500 text-sm mt-2 font-medium dark:text-gray-400">{count} articles</p>
  </div>
</a>