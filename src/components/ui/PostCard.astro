---
// src/components/ui/PostCard.astro
import { formatDate } from '../../utils/helpers';

interface Props {
  title: string;
  slug: string;
  description: string;
  category: string;
  categorySlug: string;
  author: string;
  readTime: string;
  image: string;
  featured?: boolean;
}

const { title, slug, description, category, categorySlug, author, readTime, image, featured = false } = Astro.props;
---

<article class={`post-card group bg-cream rounded-2xl overflow-hidden border border-sage/10 shadow-sm hover:shadow-md transition-shadow ${featured ? 'md:col-span-2' : ''}`}>
  <div class={`relative overflow-hidden ${featured ? 'h-64' : 'h-52'}`}>
    <img src={image} alt={title} class="post-img w-full h-full object-cover" loading="lazy" transition:name={`hero-${title}`} />
    <span class="absolute top-3 left-3 tag bg-white/90 text-forest px-2.5 py-1 rounded-full shadow-sm">
      {category}
    </span>
  </div>
  <div class="p-6">
    <h3 class="font-display text-xl text-bark group-hover:text-forest transition-colors mb-2 leading-snug">
      <a href={`/blog/${slug}/`}>{title}</a>
    </h3>
    <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-2">{description}</p>
    <div class="flex items-center justify-between text-xs text-gray-400">
      <span>{author}</span>
      <span>{readTime} read</span>
    </div>
  </div>
</article>