---
// src/components/ui/PostCard.astro
import { formatDate } from '../../utils/helpers';

interface Props {
  title: string;
  slug: string;
  description: string;
  category: string;
  categorySlug: string;
  author: string;
  readTime: string;
  image: string;
  featured?: boolean;
}

const { title, slug, description, category, categorySlug, author, readTime, image, featured = false } = Astro.props;
---

<article class={`post-card group bg-white rounded-2xl overflow-hidden border border-sage/10 shadow-soft hover:shadow-xl transition-all duration-400 dark:bg-gray-800 dark:border-gray-700/20 ${featured ? 'md:col-span-2' : ''}`}>
  <div class={`relative overflow-hidden bg-gradient-warm ${featured ? 'h-64' : 'h-52'}`}>
    <img src={image} alt={title} class="post-img w-full h-full object-cover" loading="lazy" transition:name={`hero-${title}`} />
    <span class="absolute top-3 left-3 tag bg-white/95 text-forest px-2.5 py-1 rounded-full shadow-md dark:bg-gray-800/95 dark:text-leaf">
      {category}
    </span>
  </div>
  <div class="p-6">
    <h3 class="font-display text-xl text-bark group-hover:text-forest transition-colors mb-3 leading-snug dark:text-gray-100 dark:group-hover:text-leaf">
      <a href={`/blog/${slug}/`}>{title}</a>
    </h3>
    <p class="text-gray-600 text-sm leading-relaxed mb-4 line-clamp-2 dark:text-gray-300">{description}</p>
    <div class="flex items-center justify-between text-xs text-gray-500 pt-4 border-t border-sage/10 dark:text-gray-400 dark:border-gray-700/20">
      <span class="font-medium">{author}</span>
      <span class="text-forest font-semibold">{readTime}</span>
    </div>
  </div>
</article>