---
// src/components/layout/Footer.astro
import { getCollection } from 'astro:content';

const latestPost = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0];

const categories = [
  { name: 'Home Decor', slug: 'home-decor', emoji: '🏡' },
  { name: 'Gardening', slug: 'gardening', emoji: '🌱' },
  { name: 'DIY Projects', slug: 'diy', emoji: '🔨' },
  { name: 'Kitchen', slug: 'kitchen', emoji: '🍽' },
];

const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Privacy Policy', href: '/privacy-policy/' },
];

const socialLinks = [
  { icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M8 12a4 4 0 1 0 8 0c0-1.5-.5-2.5-1-3.5s-1-2-1-2.5c0-1.5 1-3 3-3s3 1.5 3 3c0 .5-.5 1.5-1 2.5s-1 2-1 3.5a4 4 0 1 0-8 0z"></path><path d="M12 22v-8"></path></svg>`, label: 'Pinterest' },
  { icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="m16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>`, label: 'Instagram' },
  { icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>`, label: 'Facebook' },
  { icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>`, label: 'Twitter' },
];
---

<footer class="bg-gradient-to-b from-bark to-black/95 text-white/75 mt-auto dark:from-gray-800 dark:to-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-gradient-forest rounded-full flex items-center justify-center text-white font-bold shadow-lg">🌿</div>
          <span class="font-display text-2xl text-white font-bold">Bloom & Grow</span>
        </div>
        <p class="text-sm leading-relaxed text-white/70">
          Inspiring beautiful homes and gardens, one article at a time. Based in the United States.
        </p>
        <div class="flex gap-3 mt-6">
          {socialLinks.map((link, i) => (
            <a href="#" class="w-9 h-9 bg-white/10 hover:bg-forest/80 rounded-full flex items-center justify-center transition-all duration-300 text-sm hover:-translate-y-1" aria-label={link.label}>
              <span set:html={link.icon}></span>
            </a>
          ))}
        </div>
      </div>

      <!-- Categories -->
      <div>
        <h4 class="text-white font-bold mb-5 text-sm uppercase tracking-widest">Categories</h4>
        <ul class="space-y-3 text-sm">
          {categories.map(cat => (
            <li>
              <a href={`/${cat.slug}/`} class="text-white/70 hover:text-sage transition-all duration-300 flex items-center gap-2 group">
                <span class="group-hover:scale-125 transition-transform">{cat.emoji}</span>
                <span class="group-hover:translate-x-1 transition-transform">{cat.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-bold mb-5 text-sm uppercase tracking-widest">Quick Links</h4>
        <ul class="space-y-3 text-sm">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-white transition-all duration-300 flex items-center gap-2 group">
                <span class="inline-block group-hover:translate-x-1 transition-transform">→</span>
                <span>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Latest Post -->
      <div>
        <h4 class="text-white font-bold mb-5 text-sm uppercase tracking-widest">Latest Post</h4>
        {latestPost && (
          <a href={`/blog/${latestPost.id}/`} class="group block hover:opacity-80 transition-opacity duration-300">
            <div class="rounded-xl overflow-hidden mb-3 h-28 shadow-lg hover:shadow-xl transition-shadow">
              <img src={latestPost.data.heroImage} alt={latestPost.data.title} class="w-full h-full object-cover post-img group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <p class="text-sm text-white group-hover:text-sage transition-colors leading-snug font-display">
              {latestPost.data.title}
            </p>
            <p class="text-xs mt-1">
              {latestPost.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </p>
          </a>
        )}
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs">
      <p>© {new Date().getFullYear()} Bloom & Grow Blog. All rights reserved.</p>
      <p>Made with 🌿 for home & garden lovers</p>
    </div>
  </div>
</footer>