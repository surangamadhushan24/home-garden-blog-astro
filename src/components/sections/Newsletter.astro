---
// src/components/sections/Newsletter.astro
import NewsletterForm from '../ui/NewsletterForm.astro';
---

<section id="newsletter" class="py-20 bg-forest relative overflow-hidden">
  <div class="absolute top-0 right-0 w-80 h-80 bg-leaf/20 rounded-full -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-leaf/10 rounded-full translate-y-1/2 -translate-x-1/3 pointer-events-none"></div>

  <div class="relative max-w-2xl mx-auto px-4 sm:px-6 text-center">
    <span class="text-3xl mb-4 block">🌱</span>
    <h2 class="font-display text-3xl sm:text-4xl text-white mb-3">Get Weekly Garden & Home Tips</h2>
    <p class="text-sage text-base mb-9">Join 12,000+ readers who get fresh inspiration every Tuesday. No spam, ever.</p>

    <NewsletterForm />
  </div>
</section>