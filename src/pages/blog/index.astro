---
// src/pages/blog/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/ui/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = "All Articles";
const description = "Browse all our home decor, gardening, DIY, and kitchen articles. Find inspiration for your next project.";
---

<BaseLayout title={title} description={description}>
  <div class="bg-cream py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="tag text-forest">Blog</span>
        <h1 class="font-display text-4xl text-bark mt-2">All Articles</h1>
        <p class="text-gray-500 mt-3 max-w-md mx-auto">{sortedPosts.length} articles to inspire your home and garden</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map(post => (
          <PostCard 
            title={post.data.title}
            slug={post.id}
            description={post.data.description}
            category={post.data.category}
            categorySlug={post.data.categorySlug}
            author={post.data.author}
            readTime={post.data.readTime}
            image={post.data.heroImage}
          />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>